rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function privateAccountDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid)/private/account);
    }

    function currentBuildingId() {
      return userDoc(request.auth.uid).data.buildingId;
    }

    function isOwnDoc(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdminOf(buildingId) {
      return signedIn()
        && currentBuildingId() == buildingId
        && privateAccountDoc(request.auth.uid).data.role == "admin";
    }

    function isBuildingMember(buildingId) {
      return signedIn() && currentBuildingId() == buildingId;
    }

    function isResidentDirectoryViewer(docBuildingId) {
      return signedIn() && currentBuildingId() == docBuildingId;
    }

    function isAllowedPostCategory(category) {
      return category in ["discussion", "recommendation", "help", "service", null];
    }

    function isAllowedNotificationCategory(category) {
      return category in ["announcement", "chat", "reaction", "comment", "poll"];
    }

    function isPublicUserCreate() {
      return request.resource.data.keys().hasOnly(["displayName", "authProvider", "photoUrl", "buildingId", "apartmentId", "createdAt"])
        && request.resource.data.displayName is string
        && request.resource.data.authProvider in ["google", "password"]
        && request.resource.data.buildingId == null
        && request.resource.data.apartmentId == null;
    }

    function isSelfPublicUserUpdate() {
      return request.resource.data.keys().hasOnly(["displayName", "authProvider", "photoUrl", "buildingId", "apartmentId", "createdAt"])
        && request.resource.data.displayName is string
        && request.resource.data.buildingId == resource.data.buildingId
        && request.resource.data.apartmentId == resource.data.apartmentId
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    // First-time apartment approval: null -> assigned. Both buildingId and
    // apartmentId move together, exactly once, into the admin's own building.
    function isAdminApprovalUpdate() {
      return resource.data.buildingId == null
        && resource.data.apartmentId == null
        && request.resource.data.buildingId != null
        && request.resource.data.apartmentId != null
        && isAdminOf(request.resource.data.buildingId);
    }

    // Resident removal / deletion approval: apartmentId is released back to
    // null. buildingId is left untouched (single-building MVP; the account
    // is deactivated via accountStatus, not by erasing building history).
    function isAdminRemovalUpdate() {
      return resource.data.apartmentId != null
        && request.resource.data.apartmentId == null
        && request.resource.data.buildingId == resource.data.buildingId
        && isAdminOf(resource.data.buildingId);
    }

    function isAdminPublicUserUpdate() {
      return request.resource.data.keys().hasOnly(["displayName", "authProvider", "photoUrl", "buildingId", "apartmentId", "createdAt"])
        && request.resource.data.displayName == resource.data.displayName
        && request.resource.data.authProvider == resource.data.authProvider
        && request.resource.data.photoUrl == resource.data.photoUrl
        && request.resource.data.createdAt == resource.data.createdAt
        && (isAdminApprovalUpdate() || isAdminRemovalUpdate());
    }

    function isSelfPrivateCreate() {
      return request.resource.data.keys().hasOnly(["email", "role", "accountStatus", "fcmToken", "createdAt"])
        && request.resource.data.email is string
        && request.resource.data.role == "resident"
        && request.resource.data.accountStatus == "active";
    }

    function isSelfPrivateUpdate() {
      return request.resource.data.keys().hasOnly(["email", "role", "accountStatus", "fcmToken", "createdAt"])
        && request.resource.data.email is string
        && request.resource.data.createdAt == resource.data.createdAt
        // Self-elevation ("resident" -> "admin") is always blocked. Voluntary
        // self-demotion ("admin" -> "resident") is allowed so an outgoing
        // admin can hand off the role and then leave the building normally,
        // without needing the incoming admin to act on their behalf.
        && (
          request.resource.data.role == resource.data.role
          || (resource.data.role == "admin" && request.resource.data.role == "resident")
        )
        && request.resource.data.accountStatus in [resource.data.accountStatus, "deletion_requested"];
    }

    function isAdminPrivateUpdate(targetUid) {
      return isAdminOf(userDoc(targetUid).data.buildingId)
        && request.auth.uid != targetUid
        && request.resource.data.keys().hasOnly(["email", "role", "accountStatus", "fcmToken", "createdAt"])
        // Admin may only move role/accountStatus; email and fcmToken belong
        // to the owning user alone and must never be admin-writable.
        && request.resource.data.email == resource.data.email
        && request.resource.data.fcmToken == resource.data.fcmToken
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.role in ["resident", "admin"]
        && request.resource.data.accountStatus in ["active", "removed"];
    }

    function isPostAuthor(postId) {
      return signedIn() && (
        resource.data.authorUid == request.auth.uid ||
        get(/databases/$(database)/documents/post_authorship/$(postId)).data.authorUid == request.auth.uid
      );
    }

    function isPostAuthorForCreate() {
      return request.resource.data.isAnonymous == true
        ? request.resource.data.authorUid == null
        : request.resource.data.authorUid == request.auth.uid;
    }

    // Fields that must never move on a `posts/{postId}` update, regardless
    // of whether the author or an admin is making the edit.
    function isUnchangedPostCore() {
      return request.resource.data.buildingId == resource.data.buildingId
        && request.resource.data.authorUid == resource.data.authorUid
        && request.resource.data.isAnonymous == resource.data.isAnonymous
        && request.resource.data.reactionCount == resource.data.reactionCount
        && request.resource.data.commentCount == resource.data.commentCount
        && request.resource.data.bookmarkCount == resource.data.bookmarkCount
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function isAuthorPostEdit(postId) {
      return isPostAuthor(postId)
        && isUnchangedPostCore()
        && request.resource.data.text is string
        && isAllowedPostCategory(request.resource.data.category)
        && request.resource.data.isPinned == resource.data.isPinned
        && request.resource.data.isLocked == resource.data.isLocked;
    }

    function isAdminPostModeration() {
      return isAdminOf(resource.data.buildingId)
        && isUnchangedPostCore()
        && request.resource.data.text == resource.data.text
        && request.resource.data.category == resource.data.category
        && request.resource.data.isPinned is bool
        && request.resource.data.isLocked is bool;
    }

    match /buildings/{buildingId} {
      allow read: if isBuildingMember(buildingId);
      allow create, update, delete: if isAdminOf(buildingId);
    }

    match /users/{uid} {
      allow read: if isOwnDoc(uid) || isResidentDirectoryViewer(resource.data.buildingId) || isAdminOf(resource.data.buildingId);
      allow create: if isOwnDoc(uid) && isPublicUserCreate();
      allow update: if (isOwnDoc(uid) && isSelfPublicUserUpdate()) || (isAdminOf(resource.data.buildingId) && isAdminPublicUserUpdate());
      allow delete: if false;

      match /private/account {
        allow read: if isOwnDoc(uid) || isAdminOf(userDoc(uid).data.buildingId);
        allow create: if isOwnDoc(uid) && isSelfPrivateCreate();
        allow update: if (isOwnDoc(uid) && isSelfPrivateUpdate()) || isAdminPrivateUpdate(uid);
        allow delete: if false;
      }
    }

    match /apartments/{apartmentId} {
      // `occupied` requires a bound resident, and every other status
      // requires the binding to be cleared -- the two can never desync.
      function isOccupiedWriteValid() {
        return (request.resource.data.status == "occupied" && request.resource.data.primaryResidentUid != null)
          || (request.resource.data.status != "occupied" && request.resource.data.primaryResidentUid == null);
      }

      allow read: if isBuildingMember(resource.data.buildingId);
      allow create: if isAdminOf(request.resource.data.buildingId) && isOccupiedWriteValid();
      allow update: if isAdminOf(request.resource.data.buildingId) && isOccupiedWriteValid();
      allow delete: if isAdminOf(resource.data.buildingId);
    }

    match /apartment_requests/{uid} {
      allow read: if isOwnDoc(uid) || isAdminOf(resource.data.buildingId);
      allow create: if isOwnDoc(uid)
        && request.resource.data.keys().hasOnly(["buildingId", "apartmentId", "familyNote", "status", "decidedBy", "createdAt", "decidedAt"])
        && request.resource.data.buildingId == currentBuildingId()
        && userDoc(request.auth.uid).data.apartmentId == null
        && (!exists(/databases/$(database)/documents/apartment_requests/$(uid)) || get(/databases/$(database)/documents/apartment_requests/$(uid)).data.status != "pending")
        && request.resource.data.status == "pending"
        && request.resource.data.decidedBy == null
        && request.resource.data.decidedAt == null;
      // Only a still-pending request can be decided, only status/decidedBy/
      // decidedAt may change, and decidedBy must be the acting admin -- not
      // an arbitrary uid the client could otherwise attribute the decision to.
      allow update: if isAdminOf(resource.data.buildingId)
        && resource.data.status == "pending"
        && request.resource.data.buildingId == resource.data.buildingId
        && request.resource.data.apartmentId == resource.data.apartmentId
        && request.resource.data.familyNote == resource.data.familyNote
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.status in ["approved", "rejected"]
        && request.resource.data.decidedBy == request.auth.uid
        && request.resource.data.decidedAt is timestamp;
      allow delete: if false;
    }

    match /posts/{postId} {
      allow read: if isBuildingMember(resource.data.buildingId);
      allow create: if isBuildingMember(request.resource.data.buildingId)
        && request.resource.data.keys().hasOnly(["buildingId", "authorUid", "isAnonymous", "category", "text", "isPinned", "isLocked", "reactionCount", "commentCount", "bookmarkCount", "createdAt", "updatedAt"])
        && request.resource.data.text is string
        && request.resource.data.isAnonymous is bool
        && isAllowedPostCategory(request.resource.data.category)
        && isPostAuthorForCreate()
        && request.resource.data.isPinned == false
        && request.resource.data.isLocked == false
        && request.resource.data.reactionCount == 0
        && request.resource.data.commentCount == 0
        && request.resource.data.bookmarkCount == 0;
      // Author may edit text/category only (category may legitimately be
      // null -- an uncategorized/anonymous-by-default post must stay
      // editable). Admin may only flip isPinned/isLocked, never the content.
      // Neither side can touch buildingId, authorUid, isAnonymous, or the
      // denormalized counters through this path.
      allow update: if isAuthorPostEdit(postId) || isAdminPostModeration();
      allow delete: if isPostAuthor(postId) || isAdminOf(resource.data.buildingId);
    }

    match /post_authorship/{postId} {
      allow read: if isAdminOf(resource.data.buildingId) || resource.data.authorUid == request.auth.uid;
      allow create: if signedIn() && request.resource.data.authorUid == request.auth.uid && isBuildingMember(request.resource.data.buildingId);
      allow update, delete: if false;
    }

    match /posts/{postId}/reactions/{uid} {
      allow read: if isBuildingMember(get(/databases/$(database)/documents/posts/$(postId)).data.buildingId);
      allow create, delete: if isOwnDoc(uid);
      allow update: if false;
    }

    match /posts/{postId}/comments/{commentId} {
      allow read: if isBuildingMember(get(/databases/$(database)/documents/posts/$(postId)).data.buildingId);
      allow create: if signedIn()
        && request.resource.data.authorUid == request.auth.uid
        && isBuildingMember(get(/databases/$(database)/documents/posts/$(postId)).data.buildingId)
        && get(/databases/$(database)/documents/posts/$(postId)).data.isLocked == false;
      // Comments are never anonymous, so only the comment's own author or an
      // admin may edit/delete it -- a post's author has no special power
      // over other residents' comments (03_RESIDENT_SYSTEM.md SS6.2).
      allow update, delete: if signedIn()
        && (
          resource.data.authorUid == request.auth.uid
          || isAdminOf(get(/databases/$(database)/documents/posts/$(postId)).data.buildingId)
        );
    }

    match /bookmarks/{bookmarkId} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow create: if signedIn() && bookmarkId == request.auth.uid + "_" + request.resource.data.postId && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn() && bookmarkId == request.auth.uid + "_" + resource.data.postId && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    match /announcements/{announcementId} {
      allow read: if isBuildingMember(resource.data.buildingId);
      allow create, update: if isAdminOf(request.resource.data.buildingId);
      allow delete: if isAdminOf(resource.data.buildingId);
    }

    match /polls/{pollId} {
      allow read: if isBuildingMember(resource.data.buildingId);
      allow create, update: if isAdminOf(request.resource.data.buildingId);
      allow delete: if isAdminOf(resource.data.buildingId);

      match /votes/{uid} {
        allow read: if isBuildingMember(get(/databases/$(database)/documents/polls/$(pollId)).data.buildingId);
        allow create: if isOwnDoc(uid)
          && get(/databases/$(database)/documents/polls/$(pollId)).data.status == "active"
          && !exists(/databases/$(database)/documents/polls/$(pollId)/votes/$(uid));
        allow update, delete: if false;
      }
    }

    match /notifications/{notificationId} {
      allow read, update, delete: if signedIn() && resource.data.recipientUid == request.auth.uid;
      allow create: if signedIn()
        && isAllowedNotificationCategory(request.resource.data.category)
        && userDoc(request.resource.data.recipientUid).data.buildingId == currentBuildingId()
        && (
          request.resource.data.category != "announcement"
          || isAdminOf(currentBuildingId())
        );
    }

    match /conversations/{conversationId} {
      allow read, update: if signedIn() && request.auth.uid in resource.data.participantUids;
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.participantUids
        && request.resource.data.participantUids.size() == 2
        && userDoc(request.resource.data.participantUids[0]).data.buildingId == currentBuildingId()
        && userDoc(request.resource.data.participantUids[1]).data.buildingId == currentBuildingId();

      match /messages/{messageId} {
        allow read, create: if signedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantUids;
        allow update, delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
